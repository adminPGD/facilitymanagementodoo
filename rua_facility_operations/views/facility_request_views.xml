<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="facility_request_view_list" model="ir.ui.view">
        <field name="name">facility.request.list</field>
        <field name="model">facility.request</field>
        <field name="arch" type="xml">
            <list decoration-danger="is_overdue" decoration-muted="state in ('cancelled','closed')">
                <field name="name"/><field name="request_type"/><field name="category_id" optional="show"/>
                <field name="state" widget="badge" decoration-info="state == 'submitted'" decoration-warning="state in ('accepted','in_progress')" decoration-success="state in ('solved','closed')"/>
                <field name="priority" widget="priority"/><field name="campus_id" optional="hide"/><field name="building_id"/>
                <field name="space_id" optional="show"/><field name="requester_id"/><field name="assigned_user_id" optional="show"/>
                <field name="sla_deadline" optional="show"/><field name="is_overdue"/><field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="facility_request_view_form" model="ir.ui.view">
        <field name="name">facility.request.form</field>
        <field name="model">facility.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Submit" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_accept" string="Accept" type="object" class="btn-primary" invisible="state != 'submitted'" groups="rua_facility_base.group_facility_supervisor"/>
                    <button name="action_reject" string="Reject" type="object" invisible="state != 'submitted'" groups="rua_facility_base.group_facility_supervisor"/>
                    <button name="action_create_work_order" string="Create Work Order" type="object" invisible="state not in ('accepted','in_progress')" groups="rua_facility_base.group_facility_supervisor"/>
                    <button name="action_start" string="Start Work" type="object" invisible="state != 'accepted'"/>
                    <button name="action_solve" string="Solved" type="object" class="btn-primary" invisible="state != 'in_progress'"/>
                    <button name="action_close" string="Close" type="object" invisible="state != 'solved'" groups="rua_facility_base.group_facility_supervisor"/>
                    <button name="action_reopen" string="Reopen" type="object" invisible="state not in ('solved','closed')"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('closed','cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,accepted,in_progress,solved,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-wrench" type="object" name="action_create_work_order" invisible="work_order_count == 0">
                            <field name="work_order_count" string="Work Orders" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group>
                        <group string="Request Info">
                            <field name="request_type"/><field name="category_id"/><field name="subcategory_id"/>
                            <field name="priority" widget="priority"/><field name="risk_level"/><field name="source"/>
                        </group>
                        <group string="Location">
                            <field name="campus_id"/><field name="building_id" domain="[('campus_id', '=', campus_id)]"/>
                            <field name="floor_id" domain="[('building_id', '=', building_id)]"/>
                            <field name="space_id" domain="[('floor_id', '=', floor_id)]"/>
                            <field name="asset_id" domain="[('space_id', '=', space_id)]" optional="show"/>
                        </group>
                    </group>
                    <group>
                        <group string="Requester">
                            <field name="requester_id"/><field name="requester_role"/><field name="department"/><field name="college"/>
                        </group>
                        <group string="Assignment">
                            <field name="assigned_team_id"/><field name="assigned_user_id"/><field name="contractor_id"/>
                            <field name="sla_id"/><field name="sla_deadline"/>
                        </group>
                    </group>

                    <!-- Event-specific fields -->
                    <group string="Event Details" invisible="request_type != 'event_preparation'">
                        <group><field name="event_name"/><field name="event_type"/><field name="expected_attendees"/></group>
                        <group><field name="event_start"/><field name="event_end"/></group>
                    </group>
                    <group string="Required Services" invisible="request_type != 'event_preparation'">
                        <group><field name="required_sound"/><field name="required_lighting"/><field name="required_photography"/><field name="required_screen"/><field name="required_chairs"/><field name="required_stage"/></group>
                        <group><field name="required_cleaning"/><field name="required_security"/><field name="required_hospitality"/><field name="required_gallery_setup"/><field name="required_technician"/></group>
                    </group>

                    <!-- Service-specific fields -->
                    <group string="Service Details" invisible="request_type != 'service_request'">
                        <group><field name="service_type"/><field name="requested_date"/></group>
                        <group><field name="requested_time" widget="float_time"/><field name="expected_duration" widget="float_time"/></group>
                    </group>

                    <!-- Observation-specific -->
                    <group string="Observation Category" invisible="request_type != 'observation'">
                        <field name="observation_category"/>
                    </group>

                    <!-- Safety-specific -->
                    <group string="Risk Type" invisible="request_type != 'safety_report'">
                        <field name="safety_risk_type"/>
                    </group>

                    <notebook>
                        <page string="Description"><field name="description"/></page>
                        <page string="Attachments"><field name="attachment_ids"/></page>
                        <page string="Resolution" invisible="state not in ('solved','closed')">
                            <field name="resolution_summary"/><field name="rejection_reason" invisible="state != 'cancelled'"/><field name="delay_reason"/>
                            <field name="close_date"/><field name="first_response_date"/>
                        </page>
                        <page string="Work Orders"><field name="work_order_ids"/></page>
                        <page string="Rating" invisible="state not in ('solved','closed')"><field name="rating_id"/></page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="facility_request_view_search" model="ir.ui.view">
        <field name="name">facility.request.search</field>
        <field name="model">facility.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/><field name="requester_id"/><field name="building_id"/><field name="space_id"/>
                <filter name="filter_my" string="My Requests" domain="[('requester_id', '=', uid)]"/>
                <filter name="filter_overdue" string="Overdue" domain="[('is_overdue', '=', True)]"/>
                <filter name="filter_maintenance" string="Maintenance Reports" domain="[('request_type', '=', 'maintenance_report')]"/>
                <filter name="filter_observation" string="Observations" domain="[('request_type', '=', 'observation')]"/>
                <filter name="filter_service" string="Service Requests" domain="[('request_type', '=', 'service_request')]"/>
                <filter name="filter_event" string="Events" domain="[('request_type', '=', 'event_preparation')]"/>
                <filter name="filter_safety" string="Safety" domain="[('request_type', '=', 'safety_report')]"/>
                <separator/>
                <filter name="filter_open" string="Open" domain="[('state', 'not in', ['closed','cancelled'])]"/>
                <separator/>
                <group>
                    <filter name="group_type" string="Type" context="{'group_by': 'request_type'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_building" string="Building" context="{'group_by': 'building_id'}"/>
                    <filter name="group_priority" string="Priority" context="{'group_by': 'priority'}"/>
                    <filter name="group_category" string="Category" context="{'group_by': 'category_id'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
