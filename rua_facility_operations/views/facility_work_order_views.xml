<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="facility_work_order_view_list" model="ir.ui.view">
        <field name="name">facility.work.order.list</field>
        <field name="model">facility.work.order</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/><field name="title"/><field name="source_request_id"/>
                <field name="state" widget="badge" decoration-info="state in ('new','assigned')" decoration-warning="state in ('in_progress','paused','waiting_parts')" decoration-success="state in ('completed','verified','closed')"/>
                <field name="priority" widget="priority"/><field name="building_id"/><field name="space_id"/>
                <field name="assigned_user_id"/><field name="contractor_id" optional="show"/>
                <field name="planned_start" optional="show"/><field name="actual_start" optional="hide"/>
                <field name="duration_hours" optional="show" widget="float_time"/>
            </list>
        </field>
    </record>

    <record id="facility_work_order_view_form" model="ir.ui.view">
        <field name="name">facility.work.order.form</field>
        <field name="model">facility.work.order</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_assign" string="Assign" type="object" invisible="state != 'new'" groups="rua_facility_base.group_facility_supervisor"/>
                    <button name="action_accept" string="Accept" type="object" class="btn-primary" invisible="state != 'assigned'"/>
                    <button name="action_start" string="Start" type="object" class="btn-primary" invisible="state != 'assigned'"/>
                    <button name="action_pause" string="Pause" type="object" invisible="state != 'in_progress'"/>
                    <button name="action_resume" string="Resume" type="object" invisible="state != 'paused'"/>
                    <button name="action_request_parts" string="Request Parts" type="object" invisible="state != 'in_progress'"/>
                    <button name="action_complete" string="Complete" type="object" class="btn-primary" invisible="state not in ('in_progress','waiting_parts')"/>
                    <button name="action_verify" string="Verify" type="object" class="btn-primary" invisible="state != 'completed'" groups="rua_facility_base.group_facility_supervisor"/>
                    <button name="action_close" string="Close" type="object" invisible="state != 'verified'" groups="rua_facility_base.group_facility_supervisor"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state in ('closed','cancelled')"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,assigned,in_progress,completed,verified,closed"/>
                </header>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1><h2><field name="title"/></h2></div>
                    <group>
                        <group string="Source"><field name="source_request_id"/><field name="source_type"/></group>
                        <group string="Assignment"><field name="team_id"/><field name="assigned_user_id"/><field name="contractor_id"/><field name="supervisor_id"/></group>
                    </group>
                    <group>
                        <group string="Location"><field name="campus_id"/><field name="building_id"/><field name="floor_id"/><field name="space_id"/><field name="asset_id"/></group>
                        <group string="Schedule"><field name="priority" widget="priority"/><field name="risk_level"/><field name="sla_deadline"/><field name="planned_start"/><field name="planned_end"/><field name="actual_start"/><field name="actual_end"/><field name="duration_hours" widget="float_time"/></group>
                    </group>
                    <notebook>
                        <page string="Description"><field name="description"/></page>
                        <page string="Checklist"><field name="checklist_line_ids"><list editable="bottom"><field name="sequence" widget="handle"/><field name="name"/><field name="is_done"/><field name="notes"/></list></field></page>
                        <page string="Materials"><field name="material_usage_ids"><list editable="bottom"><field name="product_id"/><field name="product_name"/><field name="quantity"/><field name="uom"/><field name="cost"/><field name="notes"/></list></field></page>
                        <page string="Before Photos"><field name="before_attachment_ids"/></page>
                        <page string="After Photos"><field name="after_attachment_ids"/></page>
                        <page string="Result"><field name="execution_result"/><field name="delay_reason"/><field name="verification_date"/></page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
</odoo>
