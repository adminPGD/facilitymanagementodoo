<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="facility_sla_view_list" model="ir.ui.view">
        <field name="name">facility.sla.list</field>
        <field name="model">facility.sla</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="request_type" optional="show"/>
                <field name="priority" optional="show"/>
                <field name="risk_level" optional="hide"/>
                <field name="response_time_hours"/>
                <field name="resolution_time_hours"/>
                <field name="escalation_level_1_user_id" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="facility_sla_view_form" model="ir.ui.view">
        <field name="name">facility.sla.form</field>
        <field name="model">facility.sla</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="SLA Name"/></h1>
                    </div>
                    <group>
                        <group string="Scope">
                            <field name="request_type"/>
                            <field name="priority"/>
                            <field name="risk_level"/>
                        </group>
                        <group string="Response Times">
                            <field name="response_time_hours" widget="float_time"/>
                            <field name="resolution_time_hours" widget="float_time"/>
                        </group>
                    </group>
                    <group string="Escalation">
                        <group>
                            <field name="escalation_level_1_user_id"/>
                        </group>
                        <group>
                            <field name="escalation_level_2_user_id"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Additional notes..."/>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
