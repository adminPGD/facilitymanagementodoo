<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="facility_asset_view_list" model="ir.ui.view">
        <field name="name">facility.asset.list</field>
        <field name="model">facility.asset</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/><field name="name"/><field name="asset_type"/><field name="asset_category_id"/>
                <field name="asset_status" widget="badge" decoration-success="asset_status == 'working'" decoration-warning="asset_status == 'needs_maintenance'" decoration-danger="asset_status == 'out_of_service'"/>
                <field name="building_id"/><field name="space_id"/><field name="serial_number" optional="hide"/><field name="is_under_warranty" optional="show"/>
            </list>
        </field>
    </record>
    <record id="facility_asset_view_form" model="ir.ui.view">
        <field name="name">facility.asset.form</field>
        <field name="model">facility.asset</field>
        <field name="arch" type="xml">
            <form>
                <header><field name="asset_status" widget="statusbar" statusbar_visible="working,needs_maintenance,under_maintenance,out_of_service"/></header>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title"><h1><field name="name"/></h1><h3><field name="code"/></h3></div>
                    <group><group string="Classification"><field name="asset_type"/><field name="asset_category_id"/><field name="space_id"/><field name="building_id"/><field name="campus_id"/></group>
                    <group string="Specifications"><field name="manufacturer"/><field name="model_name"/><field name="serial_number"/><field name="qr_code"/></group></group>
                    <group><group string="Financial"><field name="cost"/><field name="purchase_date"/><field name="installation_date"/><field name="useful_life_years"/><field name="vendor_id"/></group>
                    <group string="Warranty"><field name="warranty_start_date"/><field name="warranty_end_date"/><field name="is_under_warranty"/></group></group>
                    <notebook><page string="Documents"><field name="document_ids"/></page><page string="Notes"><field name="notes"/></page></notebook>
                </sheet><chatter/>
            </form>
        </field>
    </record>
</odoo>
