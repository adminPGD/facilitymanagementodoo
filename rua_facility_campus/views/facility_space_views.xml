<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="facility_space_view_list" model="ir.ui.view">
        <field name="name">facility.space.list</field>
        <field name="model">facility.space</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code" optional="hide"/>
                <field name="space_type"/>
                <field name="building_id"/>
                <field name="floor_id"/>
                <field name="operational_status" widget="badge"
                    decoration-success="operational_status == 'operational'"
                    decoration-danger="operational_status == 'closed'"/>
                <field name="readiness_status" widget="badge"
                    decoration-success="readiness_status == 'ready'"/>
                <field name="capacity"/>
                <field name="responsible_id" optional="show"/>
            </list>
        </field>
    </record>

    <record id="facility_space_view_form" model="ir.ui.view">
        <field name="name">facility.space.form</field>
        <field name="model">facility.space</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="readiness_status" widget="statusbar"
                        statusbar_visible="ready,needs_cleaning,needs_maintenance,unavailable"/>
                </header>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                        <h3><field name="full_location"/></h3>
                    </div>
                    <group>
                        <group string="Classification">
                            <field name="code"/>
                            <field name="space_type"/>
                            <field name="capacity"/>
                            <field name="is_bookable"/>
                            <field name="has_equipment"/>
                        </group>
                        <group string="Location">
                            <field name="floor_id"/>
                            <field name="building_id"/>
                            <field name="campus_id"/>
                            <field name="responsible_id"/>
                            <field name="operational_status"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Assets">
                            <field name="asset_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="asset_category_id"/>
                                    <field name="asset_status" widget="badge"/>
                                    <field name="serial_number"/>
                                </list>
                            </field>
                        </page>
                        <page string="Safety">
                            <field name="safety_notes"/>
                        </page>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="facility_space_view_search" model="ir.ui.view">
        <field name="name">facility.space.search</field>
        <field name="model">facility.space</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="code"/>
                <field name="building_id"/>
                <field name="campus_id"/>
                <filter name="filter_ready" string="Ready"
                    domain="[('readiness_status', '=', 'ready')]"/>
                <filter name="filter_needs_maintenance" string="Needs Maintenance"
                    domain="[('readiness_status', '=', 'needs_maintenance')]"/>
                <filter name="filter_bookable" string="Bookable"
                    domain="[('is_bookable', '=', True)]"/>
                <separator/>
                <group>
                    <filter name="group_building" string="Building"
                        context="{'group_by': 'building_id'}"/>
                    <filter name="group_type" string="Type"
                        context="{'group_by': 'space_type'}"/>
                    <filter name="group_status" string="Readiness"
                        context="{'group_by': 'readiness_status'}"/>
                </group>
            </search>
        </field>
    </record>
</odoo>
