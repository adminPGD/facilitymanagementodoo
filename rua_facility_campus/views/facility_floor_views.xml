<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="facility_floor_view_list" model="ir.ui.view">
        <field name="name">facility.floor.list</field>
        <field name="model">facility.floor</field>
        <field name="arch" type="xml">
            <list><field name="floor_number"/><field name="name"/><field name="code" optional="hide"/><field name="building_id"/><field name="campus_id"/><field name="operational_status" widget="badge"/><field name="space_count"/></list>
        </field>
    </record>
    <record id="facility_floor_view_form" model="ir.ui.view">
        <field name="name">facility.floor.form</field>
        <field name="model">facility.floor</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title"><h1><field name="name"/></h1></div>
                    <group><group><field name="code"/><field name="floor_number"/></group><group><field name="building_id"/><field name="campus_id"/><field name="operational_status"/></group></group>
                    <notebook><page string="Spaces"><field name="space_ids"><list><field name="name"/><field name="code"/><field name="space_type"/><field name="capacity"/><field name="readiness_status" widget="badge"/></list></field></page><page string="Notes"><field name="notes"/></page></notebook>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
